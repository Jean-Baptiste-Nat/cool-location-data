{
  "name": "cool-location-data",
  "version": "1.0.0",
  "description": "Global location intelligence data library for shipping, tax, checkout and geolocation workflows.",
  "type": "module",
  "main": "./public/location-data.js",
  "module": "./src/index.js",
  "exports": {
    ".": {
      "import": "./src/index.js",
      "default": "./public/location-data.js"
    }
  },
  "files": [
    "public",
    "src",
    "scripts",
    "functions",
    "README.md",
    "firebase.json"
  ],
  "scripts": {
    "build": "npm run update:data && npm run build:data",
    "build:data": "node scripts/generate-json.js",
    "sync:world": "node scripts/sync-world-data.js",
    "sync:assets": "npm run download:flags && npm run download:icons",
    "update:data": "node scripts/update-data.js",
    "download:flags": "node scripts/download-flags.js",
    "download:icons": "node scripts/download-icons.js",
    "test": "node --test tests/**/*.test.js functions/tests/**/*.test.cjs",
    "lint": "eslint .",
    "prepare": "npm run build:data"
  },
  "keywords": [
    "location",
    "country",
    "regions",
    "shipping",
    "taxes",
    "geolocation",
    "firebase",
    "rest-api"
  ],
  "author": "Cool Location Data",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "eslint": "^9.31.0",
    "terser": "^5.43.1"
  }
}
